# AWS EC2 server-side configuration
# AWS Console: select the Mumbai region (ap-south-1) from the region selector.
AWS_REGION=your-aws-region
# IAM Console -> Users -> <deployment user> -> Security credentials -> Access keys.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
# Shown only when creating the IAM access key; create a replacement if it is lost.
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# EC2 Console -> Launch instance -> Application and OS Images (Amazon Machine Image).
AWS_EC2_AMI_ID=your-ec2-ami-id
# EC2 Console -> Launch instance -> Instance type.
# EC2 Console -> Key Pairs; use the exact Key pair name, not the downloaded .pem filename.
AWS_EC2_KEY_NAME=your-ec2-key-pair-name
# EC2 Console -> Security Groups -> select the group -> copy its Security group ID.
AWS_EC2_SECURITY_GROUP_ID=your-ec2-security-group-id
# VPC Console -> Subnets -> select the subnet -> copy its Subnet ID.
AWS_EC2_SUBNET_ID=your-ec2-subnet-id

# Internal proxy control service. These must only be set on the server.
NVOS_CONTROL_URL=
NVOS_CONTROL_SECRET=
NVOS_VM_BASE_DOMAIN=vm.nvos.in
